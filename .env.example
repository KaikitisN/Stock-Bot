# ── Alpaca (paper trading first) ──────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_PAPER=true

# ── AI provider keys (fill in only the ones you plan to use) ──────────────
PERPLEXITY_API_KEY=your_perplexity_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# ── Kronos local model (no API key needed) ────────────────────────────────
KRONOS_REPO_PATH=../Kronos
KRONOS_MODEL_SIZE=mini

# Minimum forecast move (%) before Kronos issues BUY/SELL (default: 2.5)
KRONOS_SIGNAL_THRESHOLD_PCT=2.5

# ── Trade quality gates ───────────────────────────────────────────────────
# Minimum AI confidence to execute a trade (default: 70)
MIN_TRADE_CONFIDENCE=70
# Max simultaneous open positions (default: 5)
MAX_OPEN_POSITIONS=5
# Require price above SMA-30 for BUYs, below for SELLs (default: true)
USE_TREND_FILTER=true
# Allow opening short positions on SELL signals (default: false)
ALLOW_SHORT_SELLING=false

# ── Dashboard display ─────────────────────────────────────────────────────
# IANA timezone for timestamps (default: Europe/Athens = UTC+2/UTC+3 DST)
DISPLAY_TIMEZONE=Europe/Athens
